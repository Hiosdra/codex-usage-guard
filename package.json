{
  "name": "codex-usage-guard",
  "version": "0.2.3",
  "description": "A local Codex UserPromptSubmit hook that paces weekly usage or monthly AI Credits.",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/Hiosdra/codex-usage-guard#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Hiosdra/codex-usage-guard.git"
  },
  "bugs": {
    "url": "https://github.com/Hiosdra/codex-usage-guard/issues"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "1.3.14"
  },
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text",
    "typecheck": "bunx tsc --noEmit",
    "format": "bunx prettier --write src tests docs README.md prompt.md package.json tsconfig.json",
    "lint": "bun run typecheck && bunx prettier --check src tests docs README.md prompt.md package.json tsconfig.json",
    "build": "bun build ./src/cli.ts --compile --outfile dist/codex-usage-guard",
    "smoke": "./dist/codex-usage-guard --help"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "prettier": "3.9.6",
    "typescript": "7.0.2"
  }
}
